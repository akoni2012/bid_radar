# ---------------------------------------------------------------------------
# Tender Opportunity Agent - environment configuration
# Copy to `.env` and fill in. Any missing key degrades that stage to MOCK mode
# so the full pipeline still runs end-to-end for a demo.
# ---------------------------------------------------------------------------

# --- Tavily (live web discovery + extraction) ---
TAVILY_API_KEY=

# --- Prometheux (Vadalog reasoning engine) ---
PMTX_TOKEN=
# Format: https://api.prometheux.ai/jarvispy/<org>/<user>
JARVISPY_URL=

# --- Senso.ai (grounded knowledge base + citations) ---
SENSO_API_KEY=
SENSO_BASE_URL=https://api.senso.ai/v1

# --- ClickHouse (analytics store + change monitoring) ---
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=tenders

# --- x402 / CDP (agent payment rails) ---
# Receiving EVM wallet address that collects USDC payments.
X402_RECEIVING_ADDRESS=0x0000000000000000000000000000000000000000
# Signup-free testnet facilitator. For mainnet use:
#   https://api.cdp.coinbase.com/platform/v2/x402  (requires CDP API keys)
X402_FACILITATOR_URL=https://x402.org/facilitator
# CAIP-2 network id. Base Sepolia = eip155:84532, Base mainnet = eip155:8453
X402_NETWORK=eip155:84532
X402_LEADPACK_PRICE=$0.10
# Buyer-side wallet (only used by scripts/buy_leadpack.py to PAY the paywall).
# Generate one with: python scripts/buy_leadpack.py --new-wallet
BUYER_PRIVATE_KEY=

# --- Pipeline tuning ---
MAX_RESULTS_PER_QUERY=5
MAX_TENDERS_PER_RUN=40
FREE_TIER_LIMIT=10
SEARCH_RECENCY_DAYS=30
